{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "blockscout": {
      "type": "http",
      "url": "https://mcp.blockscout.com/mcp"
    }
{{- if .coingecko }},
    "coingecko": {
      "type": "http",
      "url": "https://mcp.api.coingecko.com/mcp"
    }
{{- end }}
{{- if .digest }},
    "digest": {
      "command": "digest",
      "args": ["serve"]
    }
{{- end }}
{{- if .recall }},
    "recall": {
      "command": "recall",
      "args": ["serve"]
    }
{{- end }}
{{- if .autoresearch }},
    "autoresearch": {
      "command": "autoresearch",
      "args": ["serve"]
    }
{{- end }}
{{- if .watchdog }},
    "watchdog": {
      "command": "watchdog",
      "args": ["serve"]
    }
{{- end }}
{{- if .prepper }},
    "prepper": {
      "command": "prepper",
      "args": ["serve"]
    }
{{- end }}
{{- if .sentinel }},
    "sentinel": {
      "command": "sentinel",
      "args": ["serve"]
    }
{{- end }}
{{- if .patchbot }},
    "patchbot": {
      "command": "patchbot",
      "args": ["serve"]
    }
{{- end }}
{{- if .signoz }},
    "signoz": {
      "command": "{{ .chezmoi.homeDir }}/.local/bin/signoz-mcp-wrapper.sh",
      "args": []
    }
{{- end }}
{{- if .datadog }},
    "datadog": {
      "type": "http",
      "url": "https://mcp.{{ .datadog_site }}/api/unstable/mcp-server/mcp"
    }
{{- end }}
{{- if .sentry }},
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/sse"
    }
{{- end }}
  }
}
